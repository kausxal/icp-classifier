{
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.py"
    },
    {
      "src": "/admin/api/(.*)",
      "dest": "/api.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/api.py"
    },
    {
      "src": "/health",
      "dest": "/api.py"
    },
    {
      "src": "/classify",
      "dest": "/api.py"
    },
    {
      "src": "/",
      "dest": "/api.py"
    }
  ]
}