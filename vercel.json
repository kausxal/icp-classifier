{
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/api.py"
    },
    {
      "src": "/health",
      "dest": "/api.py"
    },
    {
      "src": "/classify",
      "dest": "/api.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}