{
  "version": 2,
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/dist",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin/api/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/classify",
      "dest": "api.py"
    },
    {
      "src": "/health",
      "dest": "api.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/docs",
      "dest": "api.py"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|svg|ico|woff|woff2|ttf)",
      "dest": "frontend/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}