{
  "version": 2,
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/admin/api/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/health",
      "dest": "api.py"
    },
    {
      "src": "/classify",
      "dest": "api.py"
    },
    {
      "src": "/docs",
      "dest": "api.py"
    },
    {
      "src": "/openapi.json",
      "dest": "api.py"
    }
  ]
}